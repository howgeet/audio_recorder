<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v4 source file for Meeting Transcriber Pro MSI installer.
  
  Prerequisites:
    - WiX Toolset v4: https://wixtoolset.org/  (winget install WiXToolset.WiX)
    - .NET 6 SDK (required by WiX v4 CLI)
  
  Build:
    Run build.bat from the project root, or manually:
      wix build installer\MeetingTranscriber.wxs -o dist\MeetingTranscriber.msi
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package
    Name="Meeting Transcriber Pro"
    Version="1.0.0"
    Manufacturer="Meeting Transcriber Team"
    UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
    Codepage="1252"
    Language="1033"
    Compressed="yes"
    InstallerVersion="500">

    <!-- ================================================================
         Upgrade handling – remove older versions before installing new
    ================================================================ -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of Meeting Transcriber Pro is already installed."
      Schedule="afterInstallInitialize" />

    <!-- ================================================================
         Media / cabinet
    ================================================================ -->
    <MediaTemplate EmbedCab="yes" />

    <!-- ================================================================
         UI – built-in WiX minimal UI (progress + finish dialog)
         Replace with WixUI_InstallDir for a full wizard experience.
    ================================================================ -->
    <WixVariable Id="WixUILicenseRtf" Value="installer\license.rtf" />
    <ui:WixUI Id="WixUI_InstallDir" xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
      <ui:UIRef Id="WixUI_InstallDir" />
    </ui:WixUI>
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <!-- ================================================================
         Directory layout
    ================================================================ -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Meeting Transcriber Pro" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Meeting Transcriber Pro" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <!-- ================================================================
         Components – application files
         The HarvestDirectory element (wix harvest) is the recommended
         approach for large PyInstaller output folders.  Here we define
         the structure explicitly so it works without running heat/harvest.

         IMPORTANT: replace the harvest placeholder below with the real
         file list generated by:
           wix harvest dir dist\MeetingTranscriber -cg AppFiles -dr INSTALLFOLDER -out installer\AppFiles.wxs
         Then add AppFiles.wxs to the wix build command and remove the
         placeholder <Component> block below.
    ================================================================ -->

    <ComponentGroup Id="AppExecutable" Directory="INSTALLFOLDER">
      <!-- Main executable produced by PyInstaller -->
      <Component Id="MainExe" Guid="B1C2D3E4-F5A6-7890-BCDE-F12345678901">
        <File
          Id="MeetingTranscriberExe"
          Source="dist\MeetingTranscriber\MeetingTranscriber.exe"
          KeyPath="yes" />
      </Component>

      <!-- .env.example template -->
      <Component Id="EnvExample" Guid="C2D3E4F5-A6B7-8901-CDEF-123456789012">
        <File
          Id="EnvExampleFile"
          Source=".env.example"
          KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!--
      Harvested application files component group.
      After running the harvest command above, include AppFiles.wxs in your
      build command.  Until then the build script runs wix harvest automatically.
    -->
    <ComponentGroupRef Id="HarvestedAppFiles" />

    <!-- ================================================================
         Start Menu shortcut
    ================================================================ -->
    <ComponentGroup Id="Shortcuts" Directory="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcut" Guid="D3E4F5A6-B7C8-9012-DEFA-234567890123">
        <Shortcut
          Id="StartMenuShortcut"
          Name="Meeting Transcriber Pro"
          Description="Record, transcribe and summarize meetings"
          Target="[INSTALLFOLDER]MeetingTranscriber.exe"
          WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="CleanUpShortCut" Directory="ApplicationProgramsFolder" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\MeetingTranscriberPro"
          Name="installed"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ================================================================
         Desktop shortcut (optional)
    ================================================================ -->
    <ComponentGroup Id="DesktopShortcut" Directory="DesktopFolder">
      <Component Id="DesktopShortcutComp" Guid="E4F5A6B7-C8D9-0123-EFA0-345678901234">
        <Shortcut
          Id="DesktopShortcutLink"
          Name="Meeting Transcriber Pro"
          Description="Record, transcribe and summarize meetings"
          Target="[INSTALLFOLDER]MeetingTranscriber.exe"
          WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue
          Root="HKCU"
          Key="Software\MeetingTranscriberPro"
          Name="desktopShortcut"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ================================================================
         Add/Remove Programs entry
    ================================================================ -->
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <!-- <Icon Id="AppIcon" SourceFile="installer\icon.ico" /> -->

    <!-- ================================================================
         Feature tree
    ================================================================ -->
    <Feature Id="Complete" Title="Meeting Transcriber Pro" Level="1">
      <ComponentGroupRef Id="AppExecutable" />
      <ComponentGroupRef Id="HarvestedAppFiles" />
      <ComponentGroupRef Id="Shortcuts" />
      <ComponentGroupRef Id="DesktopShortcut" />
    </Feature>

  </Package>
</Wix>
